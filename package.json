{
  "name": "spaila-parser-ui",
  "version": "0.1.0",
  "private": true,
  "main": "app/electron/main.js",
  "scripts": {
    "build:renderer": "node scripts/build-renderer.mjs",
    "build:web": "node scripts/build-web.mjs",
    "watch:renderer": "node scripts/watch-renderer.mjs",
    "recover:inbox": "node scripts/recover-inbox-visibility.mjs --execute --stop-helper",
    "diagnose:inbox": "node scripts/recover-inbox-visibility.mjs",
    "start": "npm run build:renderer && electron .",
    "dev:backend": "py -m uvicorn backend.main:app --host 127.0.0.1 --port 8055 --reload",
    "dev": "npm run build:renderer && concurrently --kill-others --kill-others-on-fail -n RENDERER,ELECTRON,BACKEND -c cyan,blue,green \"npm run watch:renderer\" \"electron .\" \"npm run dev:backend\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "electron": "^36.3.2",
    "imapflow": "^1.3.2",
    "nodemailer": "^8.0.5",
    "pdf-lib": "^1.17.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.4"
  }
}
